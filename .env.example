# Nidarsha configuration

# Logging
NIDARSHA_LOG_LEVEL=INFO
NIDARSHA_LOG_DIR=logs
NIDARSHA_LOG_FILE=nidarsha.log
NIDARSHA_LOG_JSON=true

# Discovery runtime
NIDARSHA_CRAWL_DEPTH=1
NIDARSHA_RETRIES=3
NIDARSHA_TIMEOUT_SECONDS=30
NIDARSHA_PLAYWRIGHT_TIMEOUT_SECONDS=90
NIDARSHA_PLAYWRIGHT_RENDER_WAIT_SECONDS=60
NIDARSHA_USER_AGENT=NidarshaDiscoveryBot/0.1
NIDARSHA_PREFER_HTTPS=false
NIDARSHA_MANIFEST_OUTPUT_DIR=artifacts/discovery

# Google Sheets registry access
# Use a published CSV export URL or a standard Google Sheets URL.
NIDARSHA_REGISTRY_SHEET_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit#gid=0
NIDARSHA_DISCOVERY_SHEET_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit#gid=0
# Optional: if you later switch to authenticated Sheets access, keep the
# service-account credentials outside the repo and point to them here.
NIDARSHA_GOOGLE_SERVICE_ACCOUNT_FILE=path/to/service-account.json

# Optional scopes for authenticated Google Sheets access.
NIDARSHA_GOOGLE_SCOPES=https://www.googleapis.com/auth/spreadsheets,https://www.googleapis.com/auth/drive.readonly
